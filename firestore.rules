rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'admin' | 'user')
    //   - createdAt: timestamp (required)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - price: string (required)
    //   - quantity: string (optional)
    //   - location: string (optional)
    //   - date: string (optional)
    //   - category: string (required)
    //   - badge: string (optional)
    //   - description: string (required)
    //   - rating: number (optional)
    //   - image: string (optional)
    //   - sellerId: string (required)
    //   - sellerName: string (optional)
    //   - sellerAvatar: string (optional)
    //   - sellerRating: number (optional)
    //   - sellerPhone: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: services
    // Document ID: {serviceId}
    // Fields:
    //   - id: string (required)
    //   - name: string (required)
    //   - price: string (required)
    //   - location: string (optional)
    //   - category: string (required)
    //   - description: string (required)
    //   - rating: number (optional)
    //   - image: string (optional)
    //   - providerId: string (required)
    //   - providerName: string (optional)
    //   - providerAvatar: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "nterra552@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'user'] &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'description', 'sellerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is string &&
             data.category is string &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.sellerId is string &&
             data.createdAt is timestamp;
    }

    function isValidService(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'description', 'providerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is string &&
             data.category is string &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.providerId is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == 'user' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidProduct(request.resource.data) && (request.resource.data.sellerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidProduct(request.resource.data) && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidService(request.resource.data) && (request.resource.data.providerId == request.auth.uid || isAdmin());
      allow update: if isAuthenticated() && isValidService(request.resource.data) && (resource.data.providerId == request.auth.uid || isAdmin());
      allow delete: if isAuthenticated() && (resource.data.providerId == request.auth.uid || isAdmin());
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
